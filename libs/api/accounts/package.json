{
  "name": "@glint/api-accounts",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "imports": {
    "#*": "./src/*"
  },
  "exports": {
    ".": {
      "development": {
        "types": "./src/index.ts",
        "default": "./src/index.ts"
      },
      "default": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./migration": {
      "development": {
        "types": "./src/migration.ts",
        "default": "./src/migration.ts"
      },
      "default": {
        "types": "./dist/migration.d.ts",
        "default": "./dist/migration.js"
      }
    }
  },
  "scripts": {
    "build": "swc",
    "check": "shipfox-biome-check",
    "depcruise": "shipfox-depcruise",
    "test": "NODE_ENV=production shipfox-vitest-run",
    "test:postgres": "NODE_ENV=production GLINT_POSTGRES_TEST=1 shipfox-vitest-run",
    "type": "shipfox-tsc-check",
    "type:emit": "shipfox-tsc-emit"
  },
  "dependencies": {
    "@glint/api-accounts-dto": "workspace:*",
    "@glint/node-database": "workspace:*",
    "@glint/node-module": "workspace:*",
    "drizzle-orm": "^0.45.2"
  },
  "devDependencies": {
    "@shipfox/biome": "1.8.1",
    "@shipfox/depcruise": "1.0.1",
    "@shipfox/node-postgres": "0.4.0",
    "@shipfox/swc": "1.2.5",
    "@shipfox/ts-config": "1.3.7",
    "@shipfox/typescript": "1.1.5",
    "@shipfox/vitest": "1.2.1",
    "@types/node": "24.13.3"
  },
  "glint": {
    "packageType": "backend-feature",
    "environment": "node"
  }
}
