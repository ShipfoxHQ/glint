{
  "name": "@glint/workspace",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.7.0",
  "engines": {
    "node": "24.17.0",
    "pnpm": "11.7.0"
  },
  "scripts": {
    "check:architecture": "shipfox-biome-check architecture templates dev",
    "depcruise:workspace": "node architecture/check-workspace-graph.mjs",
    "local:reset": "sh dev/local-stack.sh reset",
    "local:start": "sh dev/local-stack.sh start",
    "local:stop": "sh dev/local-stack.sh stop",
    "local:test": "sh dev/local-stack.sh test",
    "test:architecture": "node --test architecture/*.test.mjs"
  },
  "devDependencies": {
    "@shipfox/biome": "1.8.1",
    "@shipfox/depcruise": "1.0.1",
    "turbo": "2.9.18"
  }
}
