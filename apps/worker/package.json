{
  "name": "@glint/app-worker",
  "private": true,
  "type": "module",
  "main": "dist/main.js",
  "imports": {
    "#*": "./src/*"
  },
  "scripts": {
    "build": "swc",
    "check": "shipfox-biome-check",
    "depcruise": "shipfox-depcruise",
    "start": "node --enable-source-maps dist/main.js",
    "test": "shipfox-vitest-run",
    "type": "shipfox-tsc-check",
    "type:emit": "shipfox-tsc-emit"
  },
  "dependencies": {
    "@glint/node-config": "workspace:*",
    "@glint/node-database": "workspace:*",
    "@glint/node-module": "workspace:*",
    "@glint/node-object-store": "workspace:*",
    "@glint/node-observability": "workspace:*",
    "@glint/node-queue": "workspace:*",
    "fastify": "5.10.0",
    "odiff-bin": "4.3.8"
  },
  "devDependencies": {
    "@shipfox/biome": "1.8.1",
    "@shipfox/depcruise": "1.0.1",
    "@shipfox/swc": "1.2.5",
    "@shipfox/ts-config": "1.3.7",
    "@shipfox/typescript": "1.1.5",
    "@shipfox/vitest": "1.2.1",
    "@types/node": "24.13.3"
  },
  "glint": {
    "packageType": "app",
    "environment": "node"
  }
}
