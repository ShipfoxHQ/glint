{
  "name": "@glint/app-web",
  "private": true,
  "type": "module",
  "imports": {
    "#*": "./src/*"
  },
  "scripts": {
    "build": "vite build",
    "check": "shipfox-biome-check",
    "depcruise": "shipfox-depcruise",
    "start": "vite --host 127.0.0.1",
    "test": "shipfox-vitest-run",
    "type": "shipfox-tsc-check",
    "type:emit": "shipfox-tsc-emit"
  },
  "dependencies": {
    "@shipfox/react-ui": "0.1.1",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@shipfox/biome": "1.8.1",
    "@shipfox/depcruise": "1.0.1",
    "@shipfox/ts-config": "1.3.7",
    "@shipfox/typescript": "1.1.5",
    "@shipfox/vitest": "1.2.1",
    "@types/node": "24.13.3",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@tailwindcss/vite": "4.3.2",
    "@vitejs/plugin-react": "6.0.3",
    "vite": "8.1.4"
  },
  "glint": {
    "packageType": "app",
    "environment": "browser"
  }
}
